# Copy this file to .env.local and fill in your Supabase credentials.
# Get these from your Supabase project: Settings → API Keys

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Publishable key (sb_publishable_...). Safe to expose in browser code.
# Respects Row Level Security policies.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# Secret key (sb_secret_...). Server-side only — used by API routes.
# Bypasses Row Level Security. Never expose to client code.
SUPABASE_SECRET_KEY=sb_secret_your_key_here
